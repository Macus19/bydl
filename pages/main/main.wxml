<!--main.wxml-->
<!-- 顶部框 -->
<view class="main-top">
  <!-- 介绍和用户头像 -->
  <view class="main-top-introduction">
    <view class="introduction-title">
      <view>广东外语外贸大学</view>
      <view>2020毕业典礼</view>
    </view>
    <!-- 个人信息头像 -->
    <view class="introduction-avatar" bindtap="turnToLoginPage">
      <image src="/images/main/my.png"></image>
    </view>
  </view>
  <!-- 轮播图 -->
  <view class="main-swiper">
    <swiper indicator-dots="true" indicator-color="#fff" indicator-active-color="#4343b7" autoplay="true" interval="2000" duration="1000" previous-margin="80rpx" next-margin="80rpx" circular="true" bindchange="swiperChange" class="swiper-banner">
      <block wx:for="{{swiperImageList}}">
        <swiper-item>
          <image src="{{item}}" class="swiper-image {{currentSwiperIndex == index ? 'slide-in':'slide-out'}}"></image>
        </swiper-item>
      </block>
    </swiper>
  </view>
</view>
<!-- 底部的两个按钮 -->
<view class="main-bottom">
<!-- 报名按钮 -->
  <index-botton button-class="sign-up" go-color="sign-up-go" mainTitle="我要报名" subTitle="截止日期*月*日" bindtap="turnToSignUpPage">
  </index-botton>
  <!-- 查看队列 -->
  <index-botton button-class="ceremony" go-color="ceremony-go" mainTitle="典礼现场" subTitle="查看典礼队列状况" bindtap="turnToCeremonyScenePage">
  </index-botton>
</view>