/* pages/login/login.wxss */
Page{
  background: url('http://106.52.187.15/marcus/background.png') no-repeat;
  background-size: contain
}
.login-container{
  width:75%;
  margin: 15vh auto;
  padding: 20rpx;
}
.login-input-box{
  display: flex;
  justify-content: space-around;
  align-items: center;
  font-size: 30rpx;
  line-height: 30rpx;
  padding: 2.5vh 10rpx;
}
.login-input-icon{
  width: 32rpx;
  height: 32rpx;
  line-height: 30rpx;
  vertical-align: middle
}
.login-input-password-icon{
  width: 30rpx;
  height: 40rpx;
  line-height: 30rpx;
  vertical-align: middle
}
.login-password-input{
  position: relative;
}
.login-input{
  line-height: 30rpx;
  vertical-align: middle
}
.login-input:first-child{
  padding-right: 40rpx;
}
.login-placeholder{
  color: #bebed4;
}
.login-button{
  display: inline-block;
  width:100%;
  height:85rpx;
  margin-top: 5vh;
  color:#fff;
  font-size: 36rpx;
  text-align: center;
  border-radius: 40rpx;
  line-height: 85rpx;
  vertical-align: middle;
}
.login-button-normal{
  background-color: #bebed4;
}
.login-button-active{
  background-color: #4343b7;
}
.login-about{
  margin-top: 3vh;
  color: #bebed4;
  font-size: 28rpx;
  text-align: center;
}
.login-input-clear{
  width:20rpx;
  height:20rpx;
  position: absolute;
  right:0;
}