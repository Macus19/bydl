<!--pages/signup/signup.wxml-->
<view class="signup-container">
  <!-- 个人信息展示 -->
  <view class="signup-info">
    <info-bar title="姓名" value="{{studentInfo.username}}">
    </info-bar>
    <info-bar title="学历" value="{{educationMap[studentInfo.education_background]}}">
    </info-bar>
    <info-bar title="学院" value="{{studentInfo.college_name}}">
    </info-bar>
    <info-bar title="专业班级" value="{{studentInfo.major_class}}">
    </info-bar>
    <info-bar title="学号" value="{{studentInfo.number}}">
    </info-bar>
    <info-bar title="学位一" value="{{studentInfo.degree1}}">
    </info-bar>
    <info-bar title="学位二" value="{{studentInfo.degree2}}">
    </info-bar>
    <info-bar title="国籍" value="{{studentInfo.nationality}}">
    </info-bar>
  </view>
  <view class="signup-operator">
    <view class="signup-about">
      <view class="signup-about-ceremony" bindtap="turnToAboutPage">
        关于毕业典礼
      </view>
      <view class="signup-about-separator">
      </view>
      <view class="signup-about-info-wrong"  bindtap="turnToWrongInfoPage">
        <text>信息有误</text>
        <image src="/images/signup/infoWrong.png" class="info-wrong-icon"></image>
      </view>
    </view>
    <button class="sign-operator-button" bindtap="confirmSignup" hover-class="blue-btn-click">确认报名</button>
    <van-dialog id="van-dialog"  confirm-button-color="#4343b7"/>
  </view>
</view>