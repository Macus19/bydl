/* components/wrongInformation/ChangeBar/ChangeBar.wxss */
.change-bar-container{
  display: flex;
  justify-content: space-around;
  padding: 10rpx 20rpx;
}
.change-bar-container-left{
  width: 75%;
}
.change-bar-title,.change-bar-value{
  display: flex;
  padding: 10rpx 10rpx;
  justify-content: space-around;
  align-items: center;
}
.change-bar-title-text,.change-bar-value-text{
  width:20%;
  color: #bebed4;
}
.wrong-title-picker,.wrong-value-picker{
  width:360rpx;
  height: 55rpx;
  display: flex;
  position: relative;
  border: solid 1px #4343b7;
  color: #333333;
  border-radius: 37rpx;
  line-height: 55rpx;
}
.change-bar-more-icon{
  width: 20rpx;
  height: 10rpx;
  position: absolute;
  top:26rpx;
  right: 20rpx;
}
.wrong-title-item,.wrong-value-item{
  width:90%;
  margin-right: 20rpx;
  text-align: right;
  padding-right: 30rpx;
}
.wrong-value-input{
  width:310rpx;
  height:55rpx;
  padding-right:50rpx ;
  position: relative;
  border: solid 1px #4343b7;
  color: #333333;
  border-radius: 37rpx;
  text-align: right;
}
.change-bar-container-right{
  width: 15%;
  line-height: 65rpx;
  vertical-align: middle;
}
.add-icon{
  width: 26rpx;
  height: 26rpx;
  padding: 10rpx;
  line-height: 65rpx;
  vertical-align: middle;
}
.del-icon{
  width: 26rpx;
  height: 4rpx;
  padding: 10rpx;
  line-height: 50rpx;
  vertical-align: middle;
}