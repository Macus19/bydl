/* components/index/IndexBotton/IndexBotton.wxss */
.index-botton{
  width:320rpx;
  height:420rpx;
  padding: 20rpx;
  position: relative;
}
.go-button{
  width:128rpx;
  height:128rpx;
  border-radius: 50%;
  text-align: center;
  line-height: 128rpx;
  vertical-align: middle;
  color: #fff;
  position: absolute;
  left:50%;
  bottom: -20rpx;
  transform: translateX(-50%)
}
.index-button-main-title{
  width:80%;
  font-weight: bold;
  margin: 30rpx auto 0 auto;
}
.index-button-subtitle{
  width:80%;
  font-size: 26rpx;
  margin: 10rpx auto;
  color:#666666
}